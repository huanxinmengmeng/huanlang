# 数据结构测试
# 测试数据结构示例的功能

导入 幻语.测试 为 测试

# 测试结构体示例
测试组 结构体测试
    测试 测试点结构体()
    开始
        结构 点
            字段 横坐标 类型 浮点64
            字段 纵坐标 类型 浮点64
        结束
        
        函数 点.新建(横 类型 浮点64, 纵 类型 浮点64) 返回 点
        开始
            return 点 { 横坐标 设为 横, 纵坐标 设为 纵 }
        结束
        
        函数 点.距离(另一点 类型 借用 点) 返回 浮点64
        开始
            令 横向差 为 横坐标 减 另一点.横坐标
            令 纵向差 为 纵坐标 减 另一点.纵坐标
            return (横向差 * 横向差 + 纵向差 * 纵向差).开平方()
        结束
        
        令 点甲 为 点.新建(0.0, 0.0)
        令 点乙 为 点.新建(3.0, 4.0)
        
        测试.断言(点甲.横坐标 等于 0.0, "点甲横坐标应该是0")
        测试.断言(点乙.纵坐标 等于 4.0, "点乙纵坐标应该是4")
        测试.断言(点甲.距离(借用 点乙) 接近 5.0, 0.001, "两点距离应该是5")
    结束
    
    测试 测试矩形结构体()
    开始
        结构 点
            字段 横坐标 类型 浮点64
            字段 纵坐标 类型 浮点64
        结束
        
        结构 矩形
            字段 左上角 类型 点
            字段 宽度 类型 浮点64
            字段 高度 类型 浮点64
        结束
        
        函数 矩形.面积() 返回 浮点64
        开始
            return 宽度 * 高度
        结束
        
        函数 矩形.周长() 返回 浮点64
        开始
            return 2 * (宽度 + 高度)
        结束
        
        令 矩形 为 矩形 {
            左上角 设为 点 { 横坐标 设为 0.0, 纵坐标 设为 0.0 },
            宽度 设为 10.0,
            高度 设为 5.0
        }
        
        测试.断言(矩形.面积() 等于 50.0, "面积应该是50")
        测试.断言(矩形.周长() 等于 30.0, "周长应该是30")
    结束
end

# 测试集合操作
测试组 集合测试
    测试 测试列表操作()
    开始
        令 列表 为 列表<整数>.新建()
        列表.追加(1)
        列表.追加(2)
        列表.追加(3)
        
        测试.断言(列表.长度() 等于 3, "列表长度应该是3")
        测试.断言(列表.获取(0) 等于 1, "第一个元素应该是1")
        
        列表.插入(1, 100)
        测试.断言(列表.长度() 等于 4, "插入后长度应该是4")
        测试.断言(列表.获取(1) 等于 100, "插入的元素应该是100")
        
        令 移除的值 为 列表.移除(1)
        测试.断言(移除的值 等于 100, "移除的值应该是100")
        测试.断言(列表.长度() 等于 3, "移除后长度应该是3")
    结束
    
    测试 测试字典操作()
    开始
        令 字典 为 字典<字符串, 整数>.新建()
        字典.插入("a", 1)
        字典.插入("b", 2)
        
        测试.断言(字典.长度() 等于 2, "字典长度应该是2")
        测试.断言(字典.获取("a") 等于 1, "a对应的值应该是1")
        
        字典.插入("a", 10)
        测试.断言(字典.获取("a") 等于 10, "更新后a对应的值应该是10")
        
        字典.移除("b")
        测试.断言(字典.长度() 等于 1, "移除后长度应该是1")
    结束
end

# 测试算法
测试组 算法测试
    测试 测试快速排序()
    开始
        函数 快速排序(数组 类型 借用 可变 列表<整数>, 低位 类型 整数, 高位 类型 整数)
        开始
            若 低位 大于等于 高位 则
                return
            结束
            
            令 基准 为 数组[高位]
            令 游标 为 低位 减 1
            
            对于 索引 在 低位..高位 中
                若 数组[索引] 小于等于 基准 则
                    游标 设为 游标 加 1
                    令 临时 为 数组[游标]
                    数组[游标] 设为 数组[索引]
                    数组[索引] 设为 临时
                结束
            结束
            
            快速排序(数组, 低位, 游标 减 1)
            快速排序(数组, 游标 加 1, 高位)
        结束
        
        令 数组 为 [5, 2, 8, 1, 9, 3]
        快速排序(借用 可变 数组, 0, 5)
        测试.断言(数组 等于 [1, 2, 3, 5, 8, 9], "排序结果应该正确")
    结束
    
    测试 测试二分查找()
    开始
        函数 二分查找(数组 类型 借用 列表<整数>, 目标 类型 整数) 返回 可选<整数>
        开始
            令 左 为 0
            令 右 为 数组.长度() 减 1
            
            当 左 小于等于 右 循环
                令 中 为 (左 加 右) 除 2
                
                若 数组[中] 等于 目标 则
                    return 有(中)
                否则若 数组[中] 小于 目标 则
                    左 设为 中 加 1
                否则
                    右 设为 中 减 1
                结束
            结束
            
            return 空
        结束
        
        令 数组 为 [1, 2, 3, 5, 8, 9]
        测试.断言(二分查找(借用 数组, 5) 等于 有(3), "应该找到5在索引3")
        测试.断言(二分查找(借用 数组, 10) 等于 空, "应该找不到10")
    结束
end

# 运行所有测试
函数 主() 返回 整数
开始
    测试.运行所有测试()
    return 0
结束
