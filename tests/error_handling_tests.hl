# 错误处理测试
# 测试错误处理示例的功能

导入 幻语.测试 为 测试

# 测试自定义错误类型
结构 验证错误
    字段 消息 类型 字符串
结束

实现 错误 对于 验证错误
    函数 错误消息() 返回 字符串
    开始
        return 消息
    结束
end

# 测试结果类型
测试组 错误处理测试
    测试 测试安全除法()
    开始
        函数 安全除法(分子 类型 整数, 分母 类型 整数) 返回 结果<整数, 字符串>
        开始
            若 分母 等于 0 则
                return 错误("除数不能为零")
            结束
            
            若 分子 除以 分母 的余数 不等于 0 则
                return 错误("结果不是整数")
            结束
            
            return 成功(分子 除以 分母)
        结束
        
        匹配 安全除法(10, 2)
            成功(结果) => 测试.断言(结果 等于 5, "10 ÷ 2 应该等于 5")
            错误(消息) => 测试.失败(消息)
        结束
        
        匹配 安全除法(10, 0)
            成功(结果) => 测试.失败("应该返回错误")
            错误(消息) => 测试.断言(消息 等于 "除数不能为零", "错误消息应该正确")
        结束
        
        匹配 安全除法(10, 3)
            成功(结果) => 测试.失败("应该返回错误")
            错误(消息) => 测试.断言(消息 等于 "结果不是整数", "错误消息应该正确")
        结束
    结束
    
    测试 测试验证函数()
    开始
        函数 验证年龄(年龄 类型 整数) 返回 结果<单元, 验证错误>
        开始
            若 年龄 小于 0 则
                return 错误(验证错误 { 消息 设为 "年龄不能为负数" })
            结束
            
            若 年龄 大于 150 则
                return 错误(验证错误 { 消息 设为 "年龄超出合理范围" })
            结束
            
            return 成功(())
        结束
        
        匹配 验证年龄(25)
            成功 => 测试.断言(真, "25岁应该验证通过")
            错误(错误) => 测试.失败(错误.错误消息())
        结束
        
        匹配 验证年龄(-5)
            成功 => 测试.失败("应该返回错误")
            错误(错误) => 测试.断言(错误.错误消息() 等于 "年龄不能为负数", "错误消息应该正确")
        结束
        
        匹配 验证年龄(200)
            成功 => 测试.失败("应该返回错误")
            错误(错误) => 测试.断言(错误.错误消息() 等于 "年龄超出合理范围", "错误消息应该正确")
        结束
    结束
    
    测试 测试错误传播()
    开始
        函数 验证年龄(年龄 类型 整数) 返回 结果<单元, 验证错误>
        开始
            若 年龄 小于 0 则
                return 错误(验证错误 { 消息 设为 "年龄不能为负数" })
            结束
            return 成功(())
        结束
        
        函数 处理年龄(年龄 类型 整数) 返回 结果<字符串, 验证错误>
        开始
            验证年龄(年龄)?
            
            若 年龄 小于 18 则
                return 成功("未成年")
            否则
                return 成功("成年人")
            结束
        结束
        
        匹配 处理年龄(20)
            成功(状态) => 测试.断言(状态 等于 "成年人", "20岁应该是成年人")
            错误(错误) => 测试.失败(错误.错误消息())
        结束
        
        匹配 处理年龄(-10)
            成功(状态) => 测试.失败("应该返回错误")
            错误(错误) => 测试.断言(错误.错误消息() 等于 "年龄不能为负数", "错误消息应该正确")
        结束
    结束
end

# 运行所有测试
函数 主() 返回 整数
开始
    测试.运行所有测试()
    return 0
结束
