# ============================================
# 10. 事后调试
# ============================================

函数 演示事后调试()
开始
    打印("\n--- 10. 事后调试 ---")

    # 捕获 panic
    打印("注册 panic 处理器...")

    错误.设置Panic处理器(函数(信息, 栈回溯) {
        打印("程序 panic!")
        打印("信息:", 信息)
        打印("栈回溯:")
        对于 帧 在 栈回溯.帧列表() 中
            打印("  ", 帧.函数名(), " at ", 帧.文件(), ":", 帧.行号())
        结束
        
        # 保存崩溃转储
        错误.保存崩溃转储("/tmp/crashdump.dmp")
    })

    # 演示崩溃（注释掉以避免实际崩溃）
    # 错误.Panic("这是一个测试 panic")

    打印("Panic 处理器已注册")
结束

