# ============================================
# 1. 基础调试技巧
# ============================================

函数 演示基础调试()
开始
    打印("\n--- 1. 基础调试技巧 ---")

    # 使用打印语句进行调试
    令 变量 = 42
    打印("变量值:", 变量)

    # 使用断点标记
    # @调试断点
    令 计算结果 = 1 + 2 + 3 + 4 + 5
    打印("计算结果:", 计算结果)

    # 单步执行
    令 a = 10
    令 b = 20
    令 c = a + b
    打印("a + b =", c)

    # 观察表达式
    令 数组 = [1, 2, 3, 4, 5]
    令 总和 = 0
    对于 元素 在 数组 中
        总和 = 总和 + 元素
    结束
    打印("数组总和:", 总和)
结束

# ============================================
# 2. 条件断点调试
# ============================================

函数 演示条件断点()
开始
    打印("\n--- 2. 条件断点调试 ---")

    # 模拟条件断点：在特定条件下暂停
    令 计数器 = 0
    令 目标值 = 0

    # @当(计数器 > 10) 断点
    对于 i 从 1 到 100
        如果 i % 7 == 0 那么
            计数器 = 计数器 + 1
            如果 计数器 == 10 那么
                目标值 = i
            结束
        结束
    结束

    打印("第 10 个 7 的倍数是:", 目标值)
    打印("计数器:", 计数器)
结束

# ============================================
# 3. 内存调试
# ============================================

函数 演示内存调试()
开始
    打印("\n--- 3. 内存调试 ---")

    # 跟踪内存分配
    打印("开始内存调试...")

    令 列表 = 新建列表()
    列表.添加(1)
    列表.添加(2)
    列表.添加(3)

    # 检查内存地址
    打印("列表地址:", 列表.地址())
    打印("列表长度:", 列表.长度())
    打印("列表容量:", 列表.容量())

    # 模拟内存泄漏检测
    令 引用计数 = 列表.引用计数()
    打印("引用计数:", 引用计数)

    # 释放后检查
    列表.释放()
    打印("列表已释放")
结束

# ============================================
# 4. 并发调试
# ============================================

函数 演示并发调试()
开始
    打印("\n--- 4. 并发调试 ---")

    # 模拟线程调试
    打印("主线程开始")

    # 创建工作线程
    线程.启动("工作线程1", || {
        打印("工作线程 1 开始执行")
        线程.睡眠(100)
        打印("工作线程 1 执行完成")
    })

    线程.启动("工作线程2", || {
        打印("工作线程 2 开始执行")
        线程.睡眠(50)
        打印("工作线程 2 执行完成")
    })

    # 等待所有线程完成
    线程.等待所有()

    打印("所有线程执行完成")

    # 调试死锁（模拟）
    演示死锁检测()
结束

函数 演示死锁检测()
开始
    打印("开始死锁检测演示...")

    # 使用锁顺序检测避免死锁
    令 锁1 = 线程.新建锁("锁A")
    令 锁2 = 线程.新建锁("锁B")

    # 始终按相同顺序获取锁以避免死锁
    锁1.锁定()
    打印("获取了锁 A")
    锁2.锁定()
    print("获取了锁 B")

    # 临界区
    打印("执行临界区代码")

    锁2.解锁()
    锁1.解锁()
    打印("已释放所有锁")
结束

# ============================================
# 5. 异步调试
# ============================================

函数 演示异步调试()
开始
    打印("\n--- 5. 异步调试 ---")

    # 异步任务追踪
    打印("启动异步任务...")

    异步.启动(async 函数() {
        打印("异步任务 1 开始")
        异步.等待(100)
        打印("异步任务 1 完成")
    })

    异步.启动(async 函数() {
        打印("异步任务 2 开始")
        异步.等待(50)
        打印("异步任务 2 完成")
    })

    # 等待所有异步任务
    异步.等待所有()

    打印("所有异步任务完成")

    # Future 调试
    演示Future调试()
结束

函数 演示Future调试()
开始
    打印("Future 调试演示...")

    令 future = 异步.新建Future(函数(完成) {
        打印("Future 开始执行")
        异步.等待(100)
        完成(42)
    })

    # 轮询 Future 状态
    如果 future.完成() 那么
        打印("Future 已完成，结果:", future.获取())
    否则
        打印("Future 尚未完成")
    结束
结束

# ============================================
# 6. 错误处理调试
# ============================================

函数 演示错误处理调试()
开始
    打印("\n--- 6. 错误处理调试 ---")

    # 使用 Result 类型进行错误处理
    演示Result模式()

    # 使用 Option 类型进行空值检查
    演示Option模式()

    # 自定义错误类型
    演示自定义错误()
结束

函数 演示Result模式()
开始
    打印("Result 模式演示...")

    # 可能失败的操作
    函数 可能失败的操作(值: 整数) -> 结果<整数, 错误>
    开始
        如果 值 < 0 那么
            返回 错误.新建("值不能为负数")
        结束
        返回 成功(值 * 2)
    结束

    # 使用 match 处理结果
    令 结果1 = 可能失败的操作(10)
    匹配 结果1
        情况 成功(值) 那么
            打印("成功:", 值)
        情况 错误(信息) 那么
            打印("错误:", 信息)
    结束

    令 结果2 = 可能失败的操作(-5)
    匹配 结果2
        情况 成功(值) 那么
            打印("成功:", 值)
        情况 错误(信息) 那么
            打印("错误:", 信息)
    结束
结束

函数 演示Option模式()
开始
    打印("Option 模式演示...")

    函数 查找元素(列表: []整数, 目标: 整数) -> 可选<整数>
    开始
        对于 i 从 0 到 列表.长度()
            如果 列表[i] == 目标 那么
                返回 一些(i)
            结束
        结束
        返回 无
    结束

    令 列表 = [1, 2, 3, 4, 5]
    
    令 索引1 = 查找元素(列表, 3)
    匹配 索引1
        情况 一些(位置) 那么
            打印("找到元素在位置:", 位置)
        情况 无 那么
            打印("未找到元素")
    结束

    令 索引2 = 查找元素(列表, 10)
    匹配 索引2
        情况 一些(位置) 那么
            打印("找到元素在位置:", 位置)
        情况 无 那么
            打印("未找到元素")
    结束
结束

函数 演示自定义错误()
开始
    打印("自定义错误类型演示...")

    # 定义错误类型
    枚举 验证错误 {
        空值错误,
        格式错误(字符串),
        范围错误 { 最小: 整数, 最大: 整数, 实际: 整数 },
    }

    # 验证函数
    函数 验证年龄(年龄: 可选<整数>) -> 结果<整数, 验证错误>
    开始
        匹配 年龄
            情况 无 那么
                返回 错误(验证错误.空值错误)
            情况 一些(值) 那么
                如果 值 < 0 那么
                    返回 错误(验证错误.范围错误 { 最小: 0, 最大: 150, 实际: 值 })
                结束
                如果 值 > 150 那么
                    返回 错误(验证错误.范围错误 { 最小: 0, 最大: 150, 实际: 值 })
                结束
                返回 成功(值)
        结束
    结束

    # 测试验证
    令 结果1 = 验证年龄(一些(25))
    匹配 结果1
        情况 成功(年龄) 那么
            打印("有效年龄:", 年龄)
        情况 错误(错误) 那么
            打印("验证失败:", 错误.描述())
    结束

    令 结果2 = 验证年龄(无)
    匹配 结果2
        情况 成功(年龄) 那么
            打印("有效年龄:", 年龄)
        情况 错误(错误) 那么
            打印("验证失败:", 错误.描述())
    结束
结束

