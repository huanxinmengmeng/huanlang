// 幻语 - 函数示例

// 简单的加法函数
函数 加法(a: 整数, b: 整数) -> 整数 {
    返回 a + b;
}

// 打印问候语的函数
函数 问候(name: 字符串) -> 无 {
    打印("你好，" + name + "！");
}

// 计算阶乘的递归函数
函数 阶乘(n: 整数) -> 整数 {
    如果 n <= 1 那么
        返回 1;
    否则
        返回 n * 阶乘(n - 1);
    结束
}

函数 主() -> 整数 {
    问候("世界");
    
    变量 x = 10;
    变量 y = 20;
    变量 z = 加法(x, y);
    
    打印(x + " + " + y + " = " + z);
    打印("5的阶乘：" + 阶乘(5));
    
    返回 0;
}
