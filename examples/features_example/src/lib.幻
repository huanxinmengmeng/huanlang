# 功能标志示例

// 条件导入
如果 特性("network") {
    导入 网络
}

如果 特性("json") {
    导入 序列化
}

如果 特性("db") {
    导入 数据库
}

导出 函数 测试功能() -> 字符串 {
    让 结果 = "启用的功能: "
    
    如果 特性("network") {
        结果 += "网络, "
    }
    
    如果 特性("json") {
        结果 += "JSON, "
    }
    
    如果 特性("db") {
        结果 += "数据库, "
    }
    
    结果 += "标准库"
    返回 结果
}

导出 函数 发送网络请求(网址: 字符串) -> 可选<字符串> {
    如果 特性("network") {
        // 实际的网络请求
        返回 一些("网络请求成功")
    } 否则 {
        返回 无
    }
}

导出 函数 处理_json(数据: 任意) -> 可选<字符串> {
    如果 特性("json") {
        // 实际的JSON处理
        返回 一些("JSON处理成功")
    } 否则 {
        返回 无
    }
}
