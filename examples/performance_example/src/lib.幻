# 性能优化示例库
# 本文件演示各种性能优化技术的使用方法

// 导出模块
导出 性能示例
导出 调试示例

模块 性能示例 {
    // ========================================
    // 1. 性能剖析示例
    // ========================================
    
    // 导入性能模块
    导入 幻语.性能 为 性能
    导入 幻语.追踪 为 追踪

    函数 演示性能剖析() 
    开始
        // 创建性能剖析器
        令 剖析器 = 性能.新建剖析器()
        
        // 开始计时
        剖析器.开始计时("复杂计算")
        
        // 执行代码
        令 结果 = 斐波那契(30)
        
        // 结束计时
        剖析器.结束计时("复杂计算")
        
        // 获取统计信息
        令 统计 = 剖析器.获取统计()
        
        // 打印结果
        打印("性能统计:", 统计)
    结束

    函数 演示追踪点()
    开始
        // 记录追踪点
        追踪.开始("数据库查询", {"查询": "SELECT * FROM users"})
        
        // 执行查询
        // ...
        
        追踪.结束("数据库查询", {"结果数": 100})
    结束

    // ========================================
    // 2. 内存优化示例
    // ========================================
    
    导入 幻语.内存 为 内存

    函数 演示内存追踪()
    开始
        // 记录分配
        内存.开始追踪()
        
        // 执行代码
        令 数据 = 分配大数组(10000)
        
        // 获取内存统计
        令 统计 = 内存.获取统计()
        打印("分配次数:", 统计.分配次数)
        打印("当前使用:", 统计.当前使用字节)
        打印("峰值使用:", 统计.峰值使用字节)
        
        内存.停止追踪()
    结束

    函数 演示内存池()
    开始
        // 创建内存池
        令 池 = 内存.新建池(64, 1000)
        
        // 分配
        令 块1 = 池.分配()
        令 块2 = 池.分配()
        
        // 释放回池
        池.释放(块1)
        池.释放(块2)
        
        打印("池可用块数:", 池.可用数量())
        打印("池已用块数:", 池.已用数量())
    结束

    函数 演示对象池()
    开始
        // 创建对象池
        令 池 = 内存.新建对象池(|| 生成连接())
        
        // 获取对象
        令 连接1 = 池.获取()
        令 连接2 = 池.获取()
        
        // 归还对象
        池.归还(连接1)
        池.归还(连接2)
        
        打印("对象池可用:", 池.可用数量())
        打印("对象池已用:", 池.已用数量())
    结束

    // ========================================
    // 3. 基准测试示例
    // ========================================
    
    导入 幻语.基准 为 基准

    函数 演示基准测试()
    开始
        // 创建基准测试组
        令 组 = 基准.新建组("字符串操作")
        
        // 添加测试
        组.测试("字符串连接", || {
            令 结果 = "Hello" + " " + "World"
            基准.防止优化(结果)
        })
        
        组.测试("字符串分割", || {
            令 文本 = "a,b,c,d,e,f,g,h"
            令 结果 = 文本.分割(",")
            基准.防止优化(结果)
        })
        
        组.测试("字符串查找", || {
            令 文本 = "这是一个包含关键字的文本"
            令 结果 = 文本.查找("关键字")
            基准.防止优化(结果)
        })
        
        // 运行并打印结果
        组.运行()
        组.打印结果()
    结束

    函数 演示回归检测()
    开始
        // 创建回归检测器
        令 检测器 = 基准.新建回归检测器(0.05) // 5% 阈值
        
        // 运行基准测试并保存基线
        令 结果 = 基准.测试("操作", 1000, || {
            执行某操作()
        })
        
        检测器.保存基线("操作", 结果)
        
        // 模拟代码变更后重新测试
        令 新结果 = 基准.测试("操作", 1000, || {
            执行某操作()
        })
        
        检测器.添加当前("操作", 新结果)
        
        // 检测回归
        令 回归列表 = 检测器.检测回归()
        
        如果 回归列表.长度() > 0 那么
            打印("检测到性能回归:")
            对于 回归 在 回归列表 中
                打印("  ", 回归.名称, ":", 回归.变化百分比, "%")
            结束
        否则
            打印("无性能回归")
        结束
    结束

    // ========================================
    // 4. 作用域计时器示例
    // ========================================

    函数 演示作用域计时器()
    开始
        // 使用作用域计时器自动记录时间
        令 剖析器 = 性能.新建剖析器()
        
        {
            令 计时器 = 性能.作用域计时器(剖析器, "自动计时操作")
            
            // 执行被计时的代码
            执行复杂计算()
        }
        
        // 计时器自动结束，记录时间
        
        打印("自动计时完成")
    结束

    // ========================================
    // 辅助函数
    // ========================================

    函数 斐波那契(数值: 整数) -> 整数
    开始
        如果 数值 <= 1 那么
            返回 数值
        结束
        返回 斐波那契(数值 - 1) + 斐波那契(数值 - 2)
    结束

    函数 分配大数组(大小: 整数) -> []整数
    开始
        返回 新 整数[大小]
    结束

    函数 生成连接() -> 连接对象
    开始
        返回 连接对象.新()
    结束

    函数 执行某操作()
    开始
        // 模拟操作
        变量 总和 = 0
        对于 i 从 0 到 1000
            总和 = 总和 + i
        结束
        返回 总和
    结束

    函数 执行复杂计算()
    开始
        变量 结果 = 0
        对于 i 从 0 到 10000
            结果 = 结果 + 斐波那契(10)
        结束
        返回 结果
    结束
结束

模块 调试示例 {
    // ========================================
    // 5. 调试工具示例
    // ========================================
    
    导入 幻语.调试 为 调试

    函数 演示栈跟踪()
    开始
        函数1()
    结束

    函数 函数1()
    开始
        函数2()
    结束

    函数 函数2()
    开始
        // 捕获并打印栈跟踪
        令 回溯 = 调试.捕获栈回溯()
        调试.打印栈回溯(回溯)
    结束

    函数 演示错误报告()
    开始
        // 创建编译错误
        令 错误 = 调试.新建错误("E001", "类型不匹配")
            .添加跨度(
                调试.新建跨度("主程序.hl", 10, 15, "期望 整数，实际是 字符串")
            )
            .添加建议("考虑使用 转为整数() 方法")
            .设置级别(调试.错误级别.错误)
        
        // 打印错误
        调试.打印错误(错误)
        
        // 导出 JSON 格式
        令 json = 调试.导出JSON(错误)
        打印("JSON 格式:", json)
    结束

    函数 演示自定义Panic处理()
    开始
        // 设置自定义 panic 处理器
        令 配置 = 调试.新建Panic配置()
        配置.打印栈跟踪 = 真
        配置.写入日志 = 真
        配置.日志路径 = "/var/log/panic.log"
        
        调试.设置Panic处理器(配置)
        
        // 触发 panic（仅用于演示）
        // 调试.Panic("这是一个测试 panic")
    结束

    函数 演示断言()
    开始
        // 简单断言
        调试.断言(1 + 1 == 2, "1 + 1 应该等于 2")
        
        // 带消息的断言
        调试.断言相等(1, 1, "值应该相等")
        
        // 检查点
        令 值 = 计算某个值()
        调试.检查点("计算完成", 值)
        
        打印("所有断言通过")
    结束

    函数 演示调试辅助()
    开始
        令 变量 = 42
        
        // 打印变量
        调试.打印变量("变量", 变量)
        
        // 打印类型
        调试.打印类型(变量)
        
        // 打印地址
        调试.打印地址(变量)
    结束

    // ========================================
    // 6. 日志系统示例
    // ========================================
    
    导入 幻语.日志 为 日志

    函数 演示日志系统()
    开始
        // 初始化日志系统
        日志.初始化()
        
        // 设置日志级别
        日志.设置级别(日志.级别.调试)
        
        // 添加文件输出
        日志.添加文件输出("/var/log/app.log")
        
        // 记录各种级别的日志
        日志.跟踪("这是跟踪日志")
        日志.调试("这是调试日志")
        日志.信息("这是信息日志")
        日志.警告("这是警告日志")
        日志.错误("这是错误日志")
    结束

    函数 演示结构化日志()
    开始
        // 创建结构化日志字段
        令 字段 = 新建 映射<字符串, 字符串>()
        字段.设置("用户", "张三")
        字段.设置("操作", "登录")
        字段.设置("结果", "成功")
        
        // 记录结构化日志
        日志.记录(日志.级别.信息, "用户操作", 字段)
    结束

    函数 演示带字段的计时()
    开始
        令 字段 = 新建 映射<字符串, 字符串>()
        字段.设置("操作", "数据库查询")
        
        日志.记录带计时(日志.级别.信息, "查询执行", 字段, || {
            // 执行被计时的操作
            执行数据库查询()
        })
    结束

    // ========================================
    // 辅助函数
    // ========================================

    函数 计算某个值() -> 整数
    开始
        返回 42
    结束

    函数 执行数据库查询()
    开始
        // 模拟查询
        返回
    结束
结束
