// 幻语 - 简单测试示例

函数 主() -> 整数 {
    打印("=== 简单测试示例 ===");
    打印("");

    // 测试基本类型
    打印("1. 测试基本类型：");
    变量 age = 25;
    变量 name = "幻语";
    变量 is_happy = 真;
    
    打印("  整数: " + age);
    打印("  字符串: " + name);
    打印("  布尔值: " + is_happy);
    打印("");

    // 测试数组
    打印("2. 测试数组：");
    变量 numbers = [1, 2, 3, 4, 5];
    打印("  数组: ");
    打印(numbers);
    打印("  数组长度: " + numbers 长度);
    打印("  第一个元素: " + (numbers 获取 0));
    打印("");

    // 测试函数
    打印("3. 测试函数：");
    变量 result = 加法(10, 20);
    打印("  10 + 20 = " + result);
    打印("");

    打印("简单测试示例完成！");

    返回 0;
}

// 简单的加法函数
函数 加法(a: 整数, b: 整数) -> 整数 {
    返回 a + b;
}