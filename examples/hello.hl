#!/usr/bin/env huan run

导入 "标准库/核心"

函数 主() 返回 整数
开始
    显示("你好，幻语！")
    显示("欢迎使用幻语编程语言")

    令 数字 = 42
    显示("数字 = " + 整数.到字符串(数字))

    当 数字 > 0 循环
    开始
        如果 数字 % 2 == 0 则
            显示(数字.到字符串() + " 是偶数")
        否则
            显示(数字.到字符串() + " 是奇数")
        结束
        数字 = 数字 - 1
    结束

    匹配 7
    开始
        1 => 显示("one")
        2 => 显示("two")
        默认 => 显示("other")
    结束

    返回 0
结束
