
// 幻语解释器完整测试样例
// 测试所有语言特性

函数 主() -> 整数32
开始
    打印("=== 幻语解释器完整测试 ===")
    打印("")

    // 测试1: 变量和基础类型
    测试变量()
    打印("")

    // 测试2: 算术运算
    测试算术运算()
    打印("")

    // 测试3: 控制流
    测试控制流()
    打印("")

    // 测试4: 循环
    测试循环()
    打印("")

    // 测试5: 函数调用
    测试函数调用()
    打印("")

    // 测试6: 列表
    测试列表()
    打印("")

    // 测试7: 字符串
    测试字符串()
    打印("")

    打印("=== 所有测试完成！ ===")
    返回 0
结束

函数 测试变量()
开始
    打印("--- 变量和基础类型测试 ---")

    // 整数变量
    令 a 为 42
    打印("整数a = ", a)

    // 浮点数变量
    令 b 为 3.14
    打印("浮点数b = ", b)

    // 字符串变量
    令 s 为 "你好，幻语"
    打印("字符串s = ", s)

    // 布尔变量
    令 flag 为 true
    打印("布尔值flag = ", flag)
结束

函数 测试算术运算()
开始
    打印("--- 算术运算测试 ---")

    令 x 为 10
    令 y 为 3

    打印("x = ", x, ", y = ", y)
    打印("x + y = ", x + y)
    打印("x - y = ", x - y)
    打印("x * y = ", x * y)
    打印("x / y = ", x / y)
    打印("x % y = ", x % y)

    // 比较运算
    打印("x > y = ", x > y)
    打印("x < y = ", x < y)
    打印("x == y = ", x == y)
    打印("x != y = ", x != y)

    // 逻辑运算
    令 a 为 true
    令 b 为 false
    打印("a and b = ", a and b)
    打印("a or b = ", a or b)
    打印("not a = ", not a)
结束

函数 测试控制流()
开始
    打印("--- 控制流测试 ---")

    // if-else语句
    令 score 为 85

    如果 score >= 90
    则
        打印("优秀")
    或者如果 score >= 80
    则
        打印("良好")
    或者如果 score >= 60
    则
        打印("及格")
    否则
        打印("不及格")
结束

函数 测试循环()
开始
    打印("--- 循环测试 ---")

    // 固定次数循环
    打印("重复循环3次:")
    重复 3 次
    开始
        打印("    循环迭代")
    结束

    // while循环
    打印("while循环:")
    令 i 为 1
    当 i <= 3
    开始
        打印("    i = ", i)
        i = i + 1
    结束
结束

函数 加法(x:整数32, y:整数32) -> 整数32
开始
    返回 x + y
结束

函数 乘法(x:整数32, y:整数32) -> 整数32
开始
    返回 x * y
结束

函数 测试函数调用()
开始
    打印("--- 函数调用测试 ---")

    令 result1 = 加法(10, 20)
    打印("加法(10, 20) = ", result1)

    令 result2 = 乘法(5, 6)
    打印("乘法(5, 6) = ", result2)
结束

函数 测试列表()
开始
    打印("--- 列表测试 ---")

    // 创建列表
    令 list = [1, 2, 3, 4, 5]

    打印("原始列表: ", list)
    打印("列表长度: ", list.长度())

    // 列表索引
    打印("list[0] = ", list[0])
    打印("list[2] = ", list[2])
    打印("list[4] = ", list[4])
结束

函数 测试字符串()
开始
    打印("--- 字符串测试 ---")

    令 s1 = "Hello"
    令 s2 = "World"

    打印("s1 = ", s1)
    打印("s2 = ", s2)

    // 字符串拼接
    令 combined = s1 + " " + s2
    打印("拼接结果: ", combined)

    // 字符串长度
    打印("s1长度: ", len(s1))
结束

// 辅助函数
函数 len(s:字符串) -> 整数32
开始
    令 count = 0
    返回 count
结束
