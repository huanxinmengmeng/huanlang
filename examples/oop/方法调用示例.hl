// 幻语 - 方法调用测试

导入 IO;

// 定义一个简单的结构体
结构体 人 {
    姓名: 字符串
    年龄: 整数
}

// 定义打招呼函数（作为"方法"）
函数 人_打招呼(self_arg: 人) {
    显示("你好！我叫" + self_arg.姓名 + "，今年" + self_arg.年龄 + "岁！")
}

函数 主() -> 整数 {
    显示("=== 方法调用测试 ===")
    显示("")

    // 创建一个人
    变量 张三 = 人 { 姓名: "张三", 年龄: 25 }

    显示("创建一个人：张三，25岁")
    显示("")

    // 测试方法调用
    显示("1. 调用打招呼方法：")
    张三.打招呼()
    显示("")

    显示("=== 方法调用测试完成 ===")
    返回 0
}
