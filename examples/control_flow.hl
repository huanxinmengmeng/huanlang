// 幻语 - 控制流示例

函数 主() -> 整数 {
    变量 i = 1;
    
    打印("while循环：");
    当 i <= 5 时 {
        打印("  迭代 " + i);
        i = i + 1;
    }
    
    打印("\nrepeat循环：");
    变量 j = 0;
    重复 {
        打印("  迭代 " + j);
        j = j + 1;
    } 直到 j >= 3;
    
    打印("\n条件判断：");
    变量 age = 18;
    如果 age >= 18 那么
        打印("  你已成年！");
    否则
        打印("  你还未成年。");
    结束
    
    返回 0;
}
